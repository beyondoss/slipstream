{
  "lineWidth": 80,
  "excludes": ["**/target/**"],
  "exec": {
    "commands": [
      {
        "exts": ["yaml", "yml"],
        "command": "yamlfmt -in",
      },
      {
        "command": "rustfmt --edition 2024",
        "exts": ["rs"],
      },
    ],
  },
  "plugins": [
    "https://plugins.dprint.dev/exec-0.6.0.json@a054130d458f124f9b5c91484833828950723a5af3f8ff2bd1523bd47b83b364",
  ],
}
